<UserControl x:Class="MonitorPurchase.MonitorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Margin="5" Background="LightGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Столбец заказов -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Width="150" Margin="5" VerticalAlignment="Bottom">
                <TextBlock Text="Заказ:" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBox x:Name="txtOrderFilter" TextChanged="OrderFilter_TextChanged"/>
            </StackPanel>

            <DataGrid x:Name="gridOrders" Grid.Row="1" AutoGenerateColumns="False" Width="150"
                      IsReadOnly="True" SelectionMode="Single" SelectionChanged="gridOrders_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Заказ" Binding="{Binding DocNumber}" Width="*" ElementStyle="{StaticResource WrapText}"/>
                    <DataGridTextColumn Header="Срок" Binding="{Binding DocDate, StringFormat='dd.MM.yy'}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Основная часть -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="0.6*"/>
                <RowDefinition Height="0.4*"/>
            </Grid.RowDefinitions>

            <!-- Панель фильтров -->
            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Bottom">
                    <StackPanel Width="100" VerticalAlignment="Bottom">
                        <TextBlock Text="Артикул:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtCodeFilter" TextChanged="Filter_TextChanged"/>
                    </StackPanel>
                    <StackPanel Width="150" VerticalAlignment="Bottom">
                        <TextBlock Text="Наименование:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtNameFilter" TextChanged="Filter_TextChanged"/>
                    </StackPanel>
                    <StackPanel Width="100" VerticalAlignment="Bottom">
                        <TextBlock Text="Обозначение:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtSymbolFilter" TextChanged="Filter_TextChanged"/>
                    </StackPanel>
                    <StackPanel Width="200" Margin="5,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Основной поставщик:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <ComboBox x:Name="cmbSupplier" SelectionChanged="Supplier_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Width="100" Margin="5,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Склад:" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtWrhFilter" TextChanged="Filter_TextChanged"/>
                    </StackPanel>
                    <CheckBox x:Name="chkIsDeficitOnly" Content="Только дефицит" Margin="5,0,10,0" 
                              Checked="IsDeficitOnly_Changed" Unchecked="IsDeficitOnly_Changed"
                              VerticalAlignment="Bottom"/>
                    <Button x:Name="btnRefresh" Content="Обновить" Width="100" Click="btnRefresh_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- DataGrid для данных -->
            <DataGrid x:Name="gridData" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="False"
                      SelectionMode="Single" CurrentCellChanged="gridData_CurrentCellChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding ItemCode}"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding ItemName}" ElementStyle="{StaticResource WrapText}"/>
                    <DataGridTextColumn Header="Обозначение" Binding="{Binding ItemSymbol}"/>
                    <DataGridTextColumn Header="ЕИ" Binding="{Binding MeasureName}"/>
                    <DataGridTextColumn Header="Клв Зак" Binding="{Binding ClientOrderCount}"/>
                    <DataGridTextColumn Header="Брутто" Binding="{Binding DemandQty, StringFormat=F3}"/>
                    <DataGridTextColumn Header="Выдано" Binding="{Binding OutQty, StringFormat=F3}"/>
                    <DataGridTextColumn Header="Резерв" Binding="{Binding FixQity, StringFormat=F3}"/>
                    <DataGridTextColumn Header="Нетто" Binding="{Binding NetQty, StringFormat=F3}"/>
                    <DataGridTextColumn Header="Остаток" Binding="{Binding RestQty, StringFormat=F3}"/>
                    <DataGridTextColumn Header="По складам" Binding="{Binding RestString}"/>
                    <DataGridTextColumn Header="Мин. ост" Binding="{Binding MinRest, StringFormat=F3}"/>
                    <DataGridTextColumn Header="Закупка" Binding="{Binding NotReceivedQty, StringFormat=F3}"/>
                    <DataGridTextColumn Header="К закупке" Binding="{Binding ToSupply, StringFormat=F3}"/>
                    <DataGridTextColumn Header="Поставщик" Binding="{Binding ClientName}"/>
                    <DataGridTextColumn Header="СХ" Binding="{Binding WrhName}"/>
                    <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected}" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Нижняя панель -->
            <Grid Grid.Row="2" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblItem" Grid.Column="0" VerticalAlignment="Center" 
           TextDecorations="Underline" Cursor="Hand" MouseLeftButtonDown="lblItem_MouseLeftButtonDown"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnSelectAll" Content="Выбрать все" Width="100" Margin="5" Click="btnSelectAll_Click"/>
                    <Button x:Name="btnResetAll" Content="Сбросить все" Width="100" Margin="5" Click="btnResetAll_Click"/>
                    <Button x:Name="btnCreateOrders" Content="Создать заказы" Width="120" Margin="5" 
            Background="LightGreen" Click="btnCreateOrders_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>