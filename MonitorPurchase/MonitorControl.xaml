<UserControl x:Class="MonitorPurchase.MonitorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorPurchase"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="1100">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель - фильтр заказов -->
        <Border Grid.Row="0" Margin="5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Заказ:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="txtOrderFilter" Width="200" TextChanged="OrderFilter_TextChanged"/>
            </StackPanel>
        </Border>

        <!-- Таблица заказов -->
        <DataGrid x:Name="gridOrders" Grid.Row="1" Margin="5" 
                  AutoGenerateColumns="True" SelectionMode="Single"
                  CurrentCellChanged="gridOrders_CurrentCellChanged">
        </DataGrid>

        <!-- Средняя панель - фильтры -->
        <Border Grid.Row="2" Margin="5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <WrapPanel Margin="0,0,0,5">
                    <CheckBox x:Name="chkIsDeficitOnly" Content="Только дефицит" 
                              Margin="5,0" Checked="IsDeficitOnly_Changed" Unchecked="IsDeficitOnly_Changed"/>
                    <TextBlock Text="Код:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtCodeFilter" Width="100" TextChanged="Filter_TextChanged"/>
                    <TextBlock Text="Наименование:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtNameFilter" Width="150" TextChanged="Filter_TextChanged"/>
                    <TextBlock Text="Символ:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtSymbolFilter" Width="100" TextChanged="Filter_TextChanged"/>
                </WrapPanel>
                <WrapPanel>
                    <TextBlock Text="Поставщик:" VerticalAlignment="Center" Margin="5,0"/>
                    <ComboBox x:Name="cmbSupplier" Width="200" SelectionChanged="Supplier_SelectionChanged"/>
                    <TextBlock Text="Склад:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtWrhFilter" Width="150" TextChanged="Filter_TextChanged"/>
                    <Button x:Name="btnRefresh" Content="Обновить" Width="100" Margin="20,0" Click="btnRefresh_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Таблица данных -->
        <DataGrid x:Name="gridData" Grid.Row="3" Margin="5" 
                  AutoGenerateColumns="False" SelectionMode="Single"
                  CurrentCellChanged="gridData_CurrentCellChanged">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Выбрать" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Код" Binding="{Binding ItemCode}" Width="100"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ItemName}" Width="200"/>
                <DataGridTextColumn Header="Символ" Binding="{Binding ItemSymbol}" Width="80"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding ClientName}" Width="150"/>
                <DataGridTextColumn Header="Склад" Binding="{Binding WrhName}" Width="120"/>
                <DataGridTextColumn Header="Потребность" Binding="{Binding Need}" Width="80"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding InStock}" Width="80"/>
                <DataGridTextColumn Header="К заказу" Binding="{Binding ToSupply}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель с информацией и кнопками -->
        <Border Grid.Row="4" Margin="5" Padding="5" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="lblItem" Grid.Column="0" VerticalAlignment="Center" 
                           TextDecorations="Underline" Cursor="Hand" MouseLeftButtonDown="lblItem_MouseLeftButtonDown"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnSelectAll" Content="Выбрать все" Width="100" Margin="5" Click="btnSelectAll_Click"/>
                    <Button x:Name="btnResetAll" Content="Сбросить все" Width="100" Margin="5" Click="btnResetAll_Click"/>
                    <Button x:Name="btnCreateOrders" Content="Создать заказы" Width="120" Margin="5" 
                            Background="LightGreen" Click="btnCreateOrders_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>